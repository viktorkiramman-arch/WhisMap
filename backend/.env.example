# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=debug
APP_VERSION=0.1.0

# Only the browser origins that can call the API. Use comma-separated values.
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://whismap:whismap@localhost:5432/whismap?schema=public

# Optional now; required when queues, distributed rate limits, and notifications are enabled.
REDIS_URL=redis://localhost:6379

# Generate a unique 32-byte-or-longer secret for each environment.
JWT_ACCESS_SECRET=replace-with-a-unique-secret-at-least-32-characters-long

# Base64-encoded 32-byte key used only by the application encryption helper.
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Maximum 256}))
DATA_ENCRYPTION_KEY_BASE64=replace-with-a-32-byte-base64-key

# Object storage is intentionally not wired yet. Keep uploads private by default.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=whismap-private-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
