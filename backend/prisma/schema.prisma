generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CAREGIVER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum HouseholdRole {
  OWNER
  MEMBER
  SITTER
}

enum CatCareType {
  INDOOR
  COMMUNITY
  FOSTER
}

enum HealthAppetite {
  EXPECTED
  LOWER_THAN_USUAL
  NOT_OBSERVED
}

enum HealthEnergy {
  TYPICAL
  QUIETER_THAN_USUAL
  MORE_ACTIVE
}

enum LitterAction {
  CLEANED
  OBSERVED
  REFILLED
}

enum BehaviourMood {
  CALM
  PLAYFUL
  HIDING
  VOCAL
  OTHER
}

enum TaskPeriod {
  MORNING
  AFTERNOON
  EVENING
  WEEKLY
  CUSTOM
}

enum ReportType {
  LOST
  FOUND
}

enum ReportStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  RESOLVED
  ARCHIVED
  REJECTED
}

enum ReportUrgency {
  NORMAL
  URGENT
}

enum ReviewStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LocationVisibility {
  APPROXIMATE
  TRUSTED_ONLY
  PRIVATE
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum MediaVisibility {
  PRIVATE
  HOUSEHOLD
  TRUSTED
  PUBLIC
}

enum MediaScanStatus {
  PENDING
  CLEAN
  REJECTED
  FAILED
}

enum ConcernSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModerationSubjectType {
  LOST_FOUND_REPORT
  SIGHTING
  COLONY
  CONCERN_REPORT
  USER
}

enum ModerationDecision {
  APPROVED
  REJECTED
  ARCHIVED
  ESCALATED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  displayName          String
  passwordHash         String?
  role                 UserRole               @default(USER)
  status               UserStatus             @default(ACTIVE)
  emailVerifiedAt      DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  ownedHouseholds      Household[]            @relation("HouseholdOwner")
  householdMemberships HouseholdMember[]
  healthObservations   HealthObservation[]    @relation("HealthObservationRecordedBy")
  feedingPlans         FeedingPlan[]          @relation("FeedingPlanCreatedBy")
  mealLogs             MealLog[]              @relation("MealLogRecordedBy")
  litterLogs           LitterLog[]            @relation("LitterLogRecordedBy")
  behaviourLogs        BehaviourLog[]         @relation("BehaviourLogRecordedBy")
  createdTasks         CareTask[]             @relation("CareTaskCreatedBy")
  taskCompletions      CareTaskCompletion[]   @relation("TaskCompletedBy")
  createdSupplies      SupplyItem[]           @relation("SupplyItemCreatedBy")
  supplyTransactions   SupplyTransaction[]    @relation("SupplyTransactionRecordedBy")
  timelineEvents       TimelineEvent[]        @relation("TimelineEventCreatedBy")
  createdSitterAccess  SitterAccess[]         @relation("SitterAccessCreatedBy")
  sitterAccesses       SitterAccess[]         @relation("SitterUser")
  lostFoundReports     LostFoundReport[]      @relation("ReportOwner")
  sightings            Sighting[]             @relation("SightingReporter")
  contactRequests      ContactRequest[]       @relation("ContactRequester")
  colonyMemberships    ColonyMembership[]
  colonyCareEvents     ColonyCareEvent[]      @relation("ColonyCareEventRecorder")
  concernReports       ConcernReport[]        @relation("ConcernReporter")
  moderationReviews    ModerationReview[]     @relation("Moderator")
  mediaAssets          MediaAsset[]           @relation("MediaOwner")
  auditEvents          AuditLog[]             @relation("AuditActor")
  refreshSessions      RefreshSession[]
  notifications        Notification[]

  @@index([status])
  @@index([role])
}

model Household {
  id            String            @id @default(cuid())
  name          String
  ownerId       String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  owner         User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members       HouseholdMember[]
  cats          CatProfile[]
  litterBoxes   LitterBox[]
  careTasks     CareTask[]
  supplyItems   SupplyItem[]
  sitterAccess  SitterAccess[]

  @@index([ownerId])
}

model HouseholdMember {
  id            String        @id @default(cuid())
  householdId   String
  userId        String
  role          HouseholdRole @default(MEMBER)
  joinedAt      DateTime      @default(now())

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

model CatProfile {
  id            String          @id @default(cuid())
  householdId   String
  name          String
  careType      CatCareType
  birthDate     DateTime?
  ageLabel      String?
  noteEncrypted String?
  photoAssetId  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  household     Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  observations  HealthObservation[]
  feedingPlans  FeedingPlan[]
  mealLogs      MealLog[]
  litterLogs    LitterLog[]     @relation("CatLitterLogs")
  behaviourLogs BehaviourLog[]
  careTasks     CareTask[]
  timeline      TimelineEvent[]

  @@index([householdId])
}

model HealthObservation {
  id          String          @id @default(cuid())
  catId       String
  recordedById String
  observedAt  DateTime        @default(now())
  appetite    HealthAppetite
  energy      HealthEnergy
  noteEncrypted String?
  createdAt   DateTime        @default(now())

  cat         CatProfile      @relation(fields: [catId], references: [id], onDelete: Cascade)
  recordedBy  User            @relation("HealthObservationRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([catId, observedAt])
  @@index([recordedById])
}

model FeedingPlan {
  id            String       @id @default(cuid())
  catId         String
  createdById   String
  name          String
  foodType      String
  instructionsEncrypted String?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cat           CatProfile   @relation(fields: [catId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("FeedingPlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  mealLogs      MealLog[]

  @@index([catId, active])
}

model MealLog {
  id            String        @id @default(cuid())
  catId         String
  planId        String?
  recordedById  String
  mealName      String
  amountLabel   String
  completed     Boolean       @default(false)
  loggedAt      DateTime      @default(now())

  cat           CatProfile    @relation(fields: [catId], references: [id], onDelete: Cascade)
  plan          FeedingPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  recordedBy    User          @relation("MealLogRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([catId, loggedAt])
}

model LitterBox {
  id            String        @id @default(cuid())
  householdId   String
  label         String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  logs          LitterLog[]

  @@index([householdId])
}

model LitterLog {
  id            String        @id @default(cuid())
  boxId         String
  catId         String?
  recordedById  String
  action        LitterAction
  noteEncrypted String?
  loggedAt      DateTime      @default(now())

  box           LitterBox     @relation(fields: [boxId], references: [id], onDelete: Cascade)
  cat           CatProfile?   @relation("CatLitterLogs", fields: [catId], references: [id], onDelete: SetNull)
  recordedBy    User          @relation("LitterLogRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([boxId, loggedAt])
  @@index([catId, loggedAt])
}

model BehaviourLog {
  id            String          @id @default(cuid())
  catId         String
  recordedById  String
  mood          BehaviourMood
  context       String?
  noteEncrypted String?
  loggedAt      DateTime        @default(now())

  cat           CatProfile      @relation(fields: [catId], references: [id], onDelete: Cascade)
  recordedBy    User            @relation("BehaviourLogRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([catId, loggedAt])
}

model CareTask {
  id            String        @id @default(cuid())
  householdId   String
  catId         String?
  createdById   String
  title         String
  period        TaskPeriod
  scheduleJson  Json?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  cat           CatProfile?   @relation(fields: [catId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("CareTaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  completions   CareTaskCompletion[]

  @@index([householdId, active])
  @@index([catId, active])
}

model CareTaskCompletion {
  id            String        @id @default(cuid())
  taskId        String
  completedById String
  completedAt   DateTime      @default(now())
  noteEncrypted String?

  task          CareTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy   User          @relation("TaskCompletedBy", fields: [completedById], references: [id], onDelete: Restrict)

  @@index([taskId, completedAt])
}

model SupplyItem {
  id            String        @id @default(cuid())
  householdId   String
  createdById   String
  name          String
  quantity      Decimal       @db.Decimal(12, 2)
  unit          String
  minimum       Decimal       @db.Decimal(12, 2)
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("SupplyItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  transactions  SupplyTransaction[]

  @@index([householdId])
  @@index([expiresAt])
}

model SupplyTransaction {
  id            String        @id @default(cuid())
  supplyItemId  String
  recordedById  String
  quantityDelta Decimal       @db.Decimal(12, 2)
  note          String?
  createdAt     DateTime      @default(now())

  supplyItem    SupplyItem    @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  recordedBy    User          @relation("SupplyTransactionRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([supplyItemId, createdAt])
}

model TimelineEvent {
  id            String        @id @default(cuid())
  catId         String
  createdById   String
  occurredAt    DateTime
  title         String
  eventType     String
  noteEncrypted String?
  createdAt     DateTime      @default(now())

  cat           CatProfile    @relation(fields: [catId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("TimelineEventCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([catId, occurredAt])
}

model SitterAccess {
  id            String        @id @default(cuid())
  householdId   String
  createdById   String
  sitterUserId  String?
  tokenHash     String?       @unique
  startsAt      DateTime
  endsAt        DateTime
  instructionsEncrypted String?
  revokedAt     DateTime?
  createdAt     DateTime      @default(now())

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("SitterAccessCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  sitterUser    User?         @relation("SitterUser", fields: [sitterUserId], references: [id], onDelete: SetNull)

  @@index([householdId, endsAt])
  @@index([sitterUserId])
}

model LostFoundReport {
  id                          String             @id @default(cuid())
  ownerId                     String
  type                        ReportType
  status                      ReportStatus       @default(DRAFT)
  reviewStatus                ReviewStatus       @default(PENDING)
  urgency                     ReportUrgency      @default(NORMAL)
  visibility                  LocationVisibility @default(APPROXIMATE)
  catName                     String?
  color                       String
  description                 String
  publicArea                  String
  approximateLatitude         Float?
  approximateLongitude        Float?
  exactLocationEncrypted      String?
  lastSeenAt                  DateTime?
  contactDetailsEncrypted     String?
  expiresAt                   DateTime?
  resolvedAt                  DateTime?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  owner                       User               @relation("ReportOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  sightings                   Sighting[]
  contactRequests             ContactRequest[]

  @@index([status, reviewStatus, createdAt])
  @@index([type, urgency, status])
  @@index([publicArea])
  @@index([expiresAt])
}

model Sighting {
  id                          String             @id @default(cuid())
  reporterId                  String
  reportId                    String?
  publicArea                  String
  approximateLatitude         Float?
  approximateLongitude        Float?
  exactLocationEncrypted      String?
  observedAt                  DateTime
  confidence                  Int
  description                 String
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  reporter                    User               @relation("SightingReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  report                      LostFoundReport?   @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([reportId, observedAt])
  @@index([publicArea, observedAt])
}

model ContactRequest {
  id                          String               @id @default(cuid())
  reportId                    String
  requesterId                 String
  message                     String
  status                      ContactRequestStatus @default(PENDING)
  expiresAt                   DateTime
  respondedAt                 DateTime?
  createdAt                   DateTime             @default(now())

  report                      LostFoundReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  requester                   User                 @relation("ContactRequester", fields: [requesterId], references: [id], onDelete: Restrict)

  @@index([reportId, status])
  @@index([requesterId, createdAt])
}

model Colony {
  id                          String             @id @default(cuid())
  name                        String
  status                      String
  publicArea                  String
  approximateLatitude         Float?
  approximateLongitude        Float?
  exactLocationEncrypted      String?
  visibility                  LocationVisibility @default(TRUSTED_ONLY)
  publicNote                  String?
  privateNoteEncrypted        String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  memberships                 ColonyMembership[]
  careEvents                  ColonyCareEvent[]

  @@index([status])
  @@index([publicArea])
}

model ColonyMembership {
  id                          String        @id @default(cuid())
  colonyId                    String
  userId                      String
  role                        HouseholdRole @default(MEMBER)
  createdAt                   DateTime      @default(now())

  colony                      Colony        @relation(fields: [colonyId], references: [id], onDelete: Cascade)
  user                        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([colonyId, userId])
  @@index([userId])
}

model ColonyCareEvent {
  id                          String        @id @default(cuid())
  colonyId                    String
  recordedById                String
  action                      String
  publicSummary               String?
  privateDetailsEncrypted     String?
  occurredAt                  DateTime      @default(now())

  colony                      Colony        @relation(fields: [colonyId], references: [id], onDelete: Cascade)
  recordedBy                  User          @relation("ColonyCareEventRecorder", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([colonyId, occurredAt])
}

model ConcernReport {
  id                          String          @id @default(cuid())
  reporterId                  String
  category                    String
  severity                    ConcernSeverity
  descriptionEncrypted        String
  publicArea                  String
  exactLocationEncrypted      String?
  observedAt                  DateTime
  reviewStatus                ReviewStatus    @default(PENDING)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  reporter                    User            @relation("ConcernReporter", fields: [reporterId], references: [id], onDelete: Restrict)

  @@index([reviewStatus, severity, createdAt])
}

model ModerationReview {
  id                          String                  @id @default(cuid())
  reviewerId                  String
  subjectType                 ModerationSubjectType
  subjectId                   String
  decision                    ModerationDecision
  noteEncrypted               String?
  createdAt                   DateTime                @default(now())

  reviewer                    User                    @relation("Moderator", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([subjectType, subjectId, createdAt])
  @@index([reviewerId, createdAt])
}

model MediaAsset {
  id                          String          @id @default(cuid())
  ownerId                     String
  entityType                  String
  entityId                    String
  objectKey                   String          @unique
  mimeType                    String
  byteSize                    Int
  visibility                  MediaVisibility @default(PRIVATE)
  scanStatus                  MediaScanStatus @default(PENDING)
  createdAt                   DateTime        @default(now())
  deletedAt                   DateTime?

  owner                       User            @relation("MediaOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([scanStatus])
}

model RefreshSession {
  id                          String        @id @default(cuid())
  userId                      String
  tokenHash                   String        @unique
  expiresAt                   DateTime
  revokedAt                   DateTime?
  createdAt                   DateTime      @default(now())

  user                        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Notification {
  id                          String             @id @default(cuid())
  userId                      String
  channel                     NotificationChannel
  status                      NotificationStatus @default(PENDING)
  title                       String
  body                        String
  payload                     Json?
  sentAt                      DateTime?
  readAt                      DateTime?
  createdAt                   DateTime           @default(now())

  user                        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model AuditLog {
  id                          String        @id @default(cuid())
  actorId                     String?
  action                      String
  entityType                  String
  entityId                    String?
  metadata                    Json?
  createdAt                   DateTime      @default(now())

  actor                       User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}
